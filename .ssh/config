#---------------------
# CONFIGURACIÓN DE SSH
#---------------------
# Formato de cada host:
#
# Host nombre_conexion
#     HostName ip_o_dominio
#     User nombre_usuario
#     Port 22
#     IdentityFile ~/.ssh/id_ed25519
#     IdentitiesOnly yes

# Configuración global
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    AddKeysToAgent yes

# Ejemplo:
# Host miservidor
#     HostName 192.168.1.100
#     User sreaper
#     IdentityFile ~/.ssh/id_ed25519
