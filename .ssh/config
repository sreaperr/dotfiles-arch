#---------------------
# CONFIGURACIÓN DE SSH
#---------------------
# Formato de cada host:
#
# Host nombre_conexion
#     HostName ip_o_dominio
#     User nombre_usuario
#     Port 22
#     IdentityFile ~/.ssh/id_ed25519
#     IdentitiesOnly yes

# Configuración global
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    AddKeysToAgent yes

# GitHub — intenta arch primero (Arch Linux), luego mac (macOS)
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/arch
    IdentityFile ~/.ssh/mac
    IdentitiesOnly yes

# Ejemplo de servidor propio:
# Host miservidor
#     HostName 192.168.1.100
#     User sreaper
#     IdentityFile ~/.ssh/arch
