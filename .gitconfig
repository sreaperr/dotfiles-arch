[user]
    name  = TU_NOMBRE
    email = TU_EMAIL

[core]
    editor     = nvim
    pager      = delta
    autocrlf   = input

[init]
    defaultBranch = main

[delta]
    navigate    = true
    line-numbers = true
    side-by-side = true
    syntax-theme = gruvbox-dark

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[alias]
    st  = status
    co  = checkout
    br  = branch
    lg  = log --oneline --graph --decorate --all
    undo = reset --soft HEAD~1
    aliases = config --get-regexp alias
