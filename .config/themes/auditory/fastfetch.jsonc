{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "~/.config/fastfetch/logo.png",
        "type": "kitty-direct",
        "width": 33,
        "height": 18,
        "padding": {
            "top": 0,
            "left": 1,
            "right": 3
        }
    },
    "display": {
        "separator": "  ",
        "color": {
            "keys": "38;2;135;203;177",
            "title": "38;2;111;167;145"
        }
    },
    "modules": [
        {
            "type": "custom",
            "format": "[38;2;111;167;145m╭─────────────────────────────────────────╮[0m"
        },
        {
            "type": "title",
            "format": "[38;2;111;167;145m│[0m  {user-name}@{host-name}"
        },
        {
            "type": "custom",
            "format": "[38;2;111;167;145m╰─────────────────────────────────────────╯[0m"
        },
        {
            "type": "custom",
            "format": " "
        },
        {
            "type": "custom",
            "format": "[38;2;111;167;145m╭─ SOFTWARE ──────────────────────────────╮[0m"
        },
        {
            "type": "os",
            "key": "   OS      "
        },
        {
            "type": "kernel",
            "key": "   KERNEL  "
        },
        {
            "type": "uptime",
            "key": "   UPTIME  "
        },
        {
            "type": "packages",
            "key": "   PKGS    "
        },
        {
            "type": "shell",
            "key": "   SHELL   "
        },
        {
            "type": "wm",
            "key": "   WM      "
        },
        {
            "type": "terminal",
            "key": "   TERM    "
        },
        {
            "type": "custom",
            "format": "[38;2;111;167;145m╰─────────────────────────────────────────╯[0m"
        },
        {
            "type": "custom",
            "format": " "
        },
        {
            "type": "custom",
            "format": "[38;2;111;167;145m╭─ HARDWARE ──────────────────────────────╮[0m"
        },
        {
            "type": "cpu",
            "key": "   CPU     ",
            "format": "{name} ({cores-logical})"
        },
        {
            "type": "gpu",
            "key": "   GPU     "
        },
        {
            "type": "memory",
            "key": "   RAM     "
        },
        {
            "type": "disk",
            "key": "   DISK    ",
            "folders": "/",
            "format": "{1} / {2} ({3})"
        },
        {
            "type": "custom",
            "format": "[38;2;111;167;145m╰─────────────────────────────────────────╯[0m"
        },
        {
            "type": "custom",
            "format": " "
        }
    ]
}
