/* ROFI — TOKYO NIGHT COLORS
 * Variables usadas por todos los layouts
 */

* {
    background:       #1a1b2e;
    background-alt:   #16213e;
    background-hover: #1e2040;
    foreground:       #c0caf5;
    foreground-dim:   #565f89;
    selected:         #7dcfff;
    active:           #bb9af7;
    urgent:           #f7768e;

    background-color: transparent;
    text-color:       @foreground;
    font:             "Hack Nerd Font 11";
}
