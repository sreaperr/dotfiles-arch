{
    "layer": "top",
    "position": "top",
    "height": 44,
    "spacing": 4,
    "exclusive": true,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/separator",
        "custom/spotify",
        "custom/discord",
        "custom/files",
        "pulseaudio",
        "bluetooth",
        "network",
        "custom/sysinfo"
    ],
    //------------------
    // WORKSPACES
    //------------------
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "󰣇 ",
            "2": "󰆍 ",
            "3": "󱓇 ",
            "4": " ",
            "5": " ",
            "6": " ",
            "7": " ",
            "8": " "
        },
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5,
                6,
                7,
                8
            ]
        }
    },
    //------------------
    // SEPARADOR
    //------------------
    "custom/separator": {
        "format": "|",
        "tooltip": false
    },
    //------------------
    // ATAJOS DE APPS
    //------------------
    "custom/spotify": {
        "format": "󰓇",
        "on-click": "bash ~/.config/waybar/spotify-menu.sh",
        "tooltip-format": "Spotify"
    },
    "custom/discord": {
        "format": "󰙯",
        "on-click": "discord",
        "tooltip-format": "Discord"
    },
    //------------------
    // RELOJ
    //------------------
    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%A, %d %B %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "mode"
    },
    //------------------
    // VOLUMEN
    //------------------
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 muted",
        "format-icons": {
            "default": [
                "󰕿",
                "󰖀",
                "󰕾"
            ]
        },
        "on-click": "bash ~/.config/waybar/audio-menu.sh",
        "tooltip-format": "{desc}"
    },
    //------------------
    // BLUETOOTH
    //------------------
    "bluetooth": {
        "format": "󰂯",
        "format-connected": "󰂱",
        "format-off": "󰂲",
        "tooltip": false
    },
    //------------------
    // RED E IP
    //------------------
    "network": {
        "format-wifi": "󰖩  {ipaddr}",
        "format-ethernet": "󰈀  {ipaddr}",
        "format-disconnected": "󰖪",
        "tooltip": false
    },
    //------------------
    // CPU + RAM (custom)
    //------------------
    "custom/sysinfo": {
        "exec": "~/.config/waybar/sysinfo.sh",
        "interval": 2,
        "format": "{}",
        "on-click": "kitty -e btop",
        "tooltip": false
    },
    //------------------
    // BANDEJA DEL SISTEMA
    //------------------
    "tray": {
        "spacing": 8,
        "show-passive-items": true
    }
}
