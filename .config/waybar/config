{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "exclusive": true,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
        "hyprland/workspaces",
        "custom/launcher",
        "custom/separator",
        "custom/firefox",
        "custom/terminal",
        "custom/files"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/powermenu",
        "pulseaudio",
        "bluetooth",
        "network",
        "custom/sysinfo",
        "tray"
    ],

    //------------------
    // WORKSPACES
    //------------------
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "¾░úç",
            "2": "¾░×À",
            "3": "¯½ä",
            "4": "¾░ûƒ",
            "5": "¯®║",
            "6": "´ÆÀ",
            "7": "¾░¡╣",
            "8": "´äø"
        },
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5, 6, 7, 8]
        }
    },

    //------------------
    // LAUNCHER
    //------------------
    "custom/launcher": {
        "format": "",
        "on-click": "rofi -show drun",
        "tooltip": false
    },

    //------------------
    // SEPARADOR
    //------------------
    "custom/separator": {
        "format": "|",
        "tooltip": false
    },

    //------------------
    // ATAJOS DE APPS
    //------------------
    "custom/firefox": {
        "format": "",
        "on-click": "firefox",
        "tooltip-format": "Firefox"
    },

    "custom/terminal": {
        "format": "",
        "on-click": "kitty",
        "tooltip-format": "Terminal"
    },

    "custom/files": {
        "format": "",
        "on-click": "kitty -e yazi",
        "tooltip-format": "Archivos"
    },

    "custom/pavucontrol": {
        "format": "¾░ò¥",
        "on-click": "pavucontrol",
        "tooltip-format": "Control de audio"
    },

    "custom/powermenu": {
        "format": "¾░ÉÑ",
        "on-click": "$HOME/.config/hypr/scripts/powermenu.sh",
        "tooltip-format": "Men├║ de energ├¡a"
    },

    //------------------
    // RELOJ
    //------------------
    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%A, %d %B %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "mode"
    },

    //------------------
    // VOLUMEN
    //------------------
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¾░Øƒ muted",
        "format-icons": {
            "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{desc}"
    },

    //------------------
    // BLUETOOTH
    //------------------
    "bluetooth": {
        "format": "¾░é»",
        "format-connected": "¾░é▒",
        "format-connected-battery": "¾░é▒ {device_battery_percentage}%",
        "format-off": "¾░é▓",
        "on-click": "bash -c \"if bluetoothctl show | grep -q 'Powered: yes'; then bluetoothctl power off; else bluetoothctl power on; fi\"",
        "tooltip-format": "{controller_alias} ┬À {controller_address}\n{num_connections} conectados",
        "tooltip-format-connected": "{controller_alias} ┬À {controller_address}\n{num_connections} conectados\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },

    //------------------
    // RED E IP
    //------------------
    "network": {
        "format-wifi": "¾░û®  {ipaddr}",
        "format-ethernet": "¾░êÇ  {ipaddr}",
        "format-disconnected": "¾░û¬  desconectado",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nGateway: {gwaddr}",
        "on-click": "nm-connection-editor"
    },

    //------------------
    // CPU + RAM (custom)
    //------------------
    "custom/sysinfo": {
        "exec": "~/.config/waybar/sysinfo.sh",
        "interval": 2,
        "format": "{}",
        "on-click": "kitty -e btop",
        "tooltip": false
    },

    //------------------
    // BANDEJA DEL SISTEMA
    //------------------
    "tray": {
        "spacing": 8,
        "show-passive-items": true
    }
}
