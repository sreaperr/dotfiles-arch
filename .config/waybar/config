{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "exclusive": true,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,

    "modules-left": [
        "hyprland/workspaces",
        "custom/launcher",
        "custom/separator",
        "custom/firefox",
        "custom/terminal",
        "custom/files"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/powermenu",
        "pulseaudio",
        "bluetooth",
        "network",
        "cpu",
        "memory",
        "tray"
    ],

    //------------------
    // WORKSPACES
    //------------------
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "¾░Żć",
            "2": "¾░×Ę",
            "3": "Ņ½ä",
            "4": "¾░¢¤",
            "5": "Ņ®║",
            "6": "’ÆĘ",
            "7": "¾░Ł╣",
            "8": "’äø"
        },
        "persistent-workspaces": {
            "*": [1, 2, 3, 4, 5, 6, 7, 8]
        }
    },

    //------------------
    // LAUNCHER
    //------------------
    "custom/launcher": {
        "format": "",
        "on-click": "rofi -show drun",
        "tooltip": false
    },

    //------------------
    // SEPARADOR
    //------------------
    "custom/separator": {
        "format": "|",
        "tooltip": false
    },

    //------------------
    // ATAJOS DE APPS
    //------------------
    "custom/firefox": {
        "format": "",
        "on-click": "firefox",
        "tooltip-format": "Firefox"
    },

    "custom/terminal": {
        "format": "",
        "on-click": "kitty",
        "tooltip-format": "Terminal"
    },

    "custom/files": {
        "format": "",
        "on-click": "kitty -e yazi",
        "tooltip-format": "Archivos"
    },

    "custom/pavucontrol": {
        "format": "¾░ĢŠ",
        "on-click": "pavucontrol",
        "tooltip-format": "Control de audio"
    },

    "custom/powermenu": {
        "format": "¾░Éź",
        "on-click": "$HOME/.config/hypr/scripts/powermenu.sh",
        "tooltip-format": "Men├║ de energ├Ła"
    },

    //------------------
    // RELOJ
    //------------------
    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%A, %d %B %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "mode"
    },

    //------------------
    // VOLUMEN
    //------------------
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¾░Ø¤ muted",
        "format-icons": {
            "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "{desc}"
    },

    //------------------
    // BLUETOOTH
    //------------------
    "bluetooth": {
        "format": "¾░é»",
        "format-connected": "¾░é▒",
        "format-connected-battery": "¾░é▒ {device_battery_percentage}%",
        "format-off": "¾░é▓",
        "on-click": "bash -c \"if bluetoothctl show | grep -q 'Powered: yes'; then bluetoothctl power off; else bluetoothctl power on; fi\"",
        "tooltip-format": "{controller_alias} ┬Ę {controller_address}\n{num_connections} conectados",
        "tooltip-format-connected": "{controller_alias} ┬Ę {controller_address}\n{num_connections} conectados\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },

    //------------------
    // RED E IP
    //------------------
    "network": {
        "format-wifi": "¾░¢®  {ipaddr}",
        "format-ethernet": "¾░łĆ  {ipaddr}",
        "format-disconnected": "¾░¢¬  desconectado",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nGateway: {gwaddr}",
        "on-click": "nm-connection-editor"
    },

    //------------------
    // CPU
    //------------------
    "cpu": {
        "format": " {usage}%",
        "tooltip-format": "CPU: {usage}%\nCarga: {load}",
        "interval": 2,
        "on-click": "kitty -e btop"
    },

    //------------------
    // RAM
    //------------------
    "memory": {
        "format": "¾░Źø {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "interval": 2,
        "on-click": "kitty -e btop"
    },

    //------------------
    // BANDEJA DEL SISTEMA
    //------------------
    "tray": {
        "spacing": 8,
        "show-passive-items": true
    }
}
