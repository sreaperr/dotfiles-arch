{
    "layer": "top",
    "position": "top",
    "height": 36,
    "spacing": 4,
    "exclusive": true,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/separator",
        "custom/spotify",
        "custom/discord",
        "custom/files",
        "pulseaudio",
        "bluetooth",
        "network",
        "custom/sysinfo",
        "custom/cc"
    ],
    //------------------
    // WORKSPACES
    //------------------
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "¾░úç ",
            "2": "¾░åì ",
            "3": "¾▒ôç ",
            "4": "´Æ│ ",
            "5": "¯«® ",
            "6": "´êƒ ",
            "7": "¯®ó ",
            "8": "¯»è "
        },
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5,
                6,
                7,
                8
            ]
        }
    },
    //------------------
    // CONTROL CENTER (panel lateral eww)
    //------------------
    "custom/cc": {
        "format": "¯Çç",
        "on-click": "~/.config/eww/scripts/toggle-cc.sh",
        "tooltip-format": "Control Center"
    },
    //------------------
    // SEPARADOR
    //------------------
    "custom/separator": {
        "format": "|",
        "tooltip": false
    },
    //------------------
    // ATAJOS DE APPS
    //------------------
    "custom/spotify": {
        "format": "¾░ôç",
        "on-click": "bash ~/.config/waybar/spotify-menu.sh",
        "tooltip-format": "Spotify"
    },
    "custom/discord": {
        "format": "¾░Ö»",
        "on-click": "discord",
        "tooltip-format": "Discord"
    },
    //------------------
    // RELOJ
    //------------------
    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%A, %d %B %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "mode"
    },
    //------------------
    // VOLUMEN
    //------------------
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "¾░Øƒ muted",
        "format-icons": {
            "default": [
                "¾░ò┐",
                "¾░ûÇ",
                "¾░ò¥"
            ]
        },
        "on-click": "bash ~/.config/waybar/audio-menu.sh",
        "tooltip-format": "{desc}"
    },
    //------------------
    // BLUETOOTH
    //------------------
    "bluetooth": {
        "format": "¾░é»",
        "format-connected": "¾░é▒",
        "format-connected-battery": "¾░é▒ {device_battery_percentage}%",
        "format-off": "¾░é▓",
        "on-click": "bash ~/.config/waybar/bluetooth-menu.sh",
        "tooltip-format": "{controller_alias} ┬À {controller_address}\n{num_connections} conectados",
        "tooltip-format-connected": "{controller_alias} ┬À {controller_address}\n{num_connections} conectados\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
    },
    //------------------
    // RED E IP
    //------------------
    "network": {
        "format-wifi": "¾░û®  {ipaddr}",
        "format-ethernet": "¾░êÇ  {ipaddr}",
        "format-disconnected": "¾░û¬  desconectado",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nGateway: {gwaddr}",
        "on-click": "bash ~/.config/waybar/network-menu.sh"
    },
    //------------------
    // CPU + RAM (custom)
    //------------------
    "custom/sysinfo": {
        "exec": "~/.config/waybar/sysinfo.sh",
        "interval": 2,
        "format": "{}",
        "on-click": "kitty -e btop",
        "tooltip": false
    },
    //------------------
    // BANDEJA DEL SISTEMA
    //------------------
    "tray": {
        "spacing": 8,
        "show-passive-items": true
    }
}
