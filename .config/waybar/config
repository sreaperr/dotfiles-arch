{
    "layer": "top",
    "position": "top",
    "height": 44,
    "spacing": 4,
    "exclusive": true,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "clock"
    ],
    "modules-center": [
        "hyprland/workspaces",
        "custom/security"
    ],
    "modules-right": [
        "custom/separator",
        "custom/spotify",
        "custom/discord",
        "custom/files",
        "pulseaudio",
        "bluetooth",
        "network",
        "custom/sysinfo"
    ],
    //------------------
    // WORKSPACES
    //------------------
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": false,
        "format-icons": {
            "1": "≤░μΘ",
            "2": "≤░ΗΞ",
            "3": "≤▒ΥΘ",
            "4": "ΎΤ│",
            "5": "Όχσ",
            "6": "ΎΙθ",
            "7": "Όσλ",
            "8": "ΌψΛ",
            "9": "≤░Ιβ",
            "10": "ΎΜκ"
        },
        "persistent-workspaces": {
            "DP-1": [
                1,
                2,
                3,
                4,
                5,
                6,
                7,
                8
            ],
            "DP-2": [
                9,
                10
            ]
        }
    },
    //------------------
    // SEPARADOR
    //------------------
    "custom/separator": {
        "format": "|",
        "tooltip": false
    },
    //------------------
    // ATAJOS DE APPS
    //------------------
    "custom/spotify": {
        "exec": "~/.config/waybar/spotify-panel.sh",
        "interval": 3,
        "return-type": "json",
        "tooltip": true,
        "on-click": "~/.config/waybar/spotify-ctl.sh play-pause",
        "on-click-right": "bash ~/.config/waybar/spotify-menu.sh",
        "on-scroll-up": "~/.config/waybar/spotify-ctl.sh previous",
        "on-scroll-down": "~/.config/waybar/spotify-ctl.sh next"
    },
    "custom/discord": {
        "format": "≤░βψ",
        "on-click": "discord",
        "tooltip-format": "Discord"
    },
    //------------------
    // RELOJ
    //------------------
    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%A, %d %B %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "mode"
    },
    //------------------
    // VOLUMEN
    //------------------
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "≤░ζθ muted",
        "format-icons": {
            "default": [
                "≤░Χ┐",
                "≤░ΨΑ",
                "≤░Χ╛"
            ]
        },
        "on-click": "bash ~/.config/waybar/audio-menu.sh",
        "tooltip-format": "{desc}"
    },
    //------------------
    // BLUETOOTH
    //------------------
    "bluetooth": {
        "format": "≤░Γψ",
        "format-connected": "≤░Γ▒",
        "format-off": "≤░Γ▓",
        "tooltip": false
    },
    //------------------
    // RED E IP
    //------------------
    "network": {
        "format-wifi": "≤░Ψσ  {ipaddr}",
        "format-ethernet": "≤░ΙΑ  {ipaddr}",
        "format-disconnected": "≤░Ψς",
        "tooltip": false
    },
    //------------------
    // CPU + RAM (custom)
    //------------------
    "custom/sysinfo": {
        "exec": "~/.config/waybar/sysinfo.sh",
        "interval": 2,
        "format": "{}",
        "on-click": "kitty -e btop",
        "tooltip": false
    },
    //------------------
    // SECURITY MONITOR
    //------------------
    "custom/security": {
        "exec": "~/.config/waybar/security-panel.sh",
        "interval": 15,
        "return-type": "json",
        "tooltip": true,
        "on-click": "~/.config/waybar/security-panel.sh | jq -r .tooltip | notify-send -t 8000 '≤░Τβ Security' \"$(cat)\""
    },
    //------------------
    // BANDEJA DEL SISTEMA
    //------------------
    "tray": {
        "spacing": 8,
        "show-passive-items": true
    }
}
