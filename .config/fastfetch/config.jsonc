{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

    "logo": {
        "source": "~/.config/fastfetch/logo.txt",
        "type": "file",
        "padding": {
            "top": 1,
            "left": 2,
            "right": 4
        },
        "color": {
            "1": "38;2;255;45;120"
        }
    },

    "display": {
        "separator": "  ",
        "color": {
            "keys":   "38;2;255;45;120",
            "title":  "38;2;255;45;120"
        }
    },

